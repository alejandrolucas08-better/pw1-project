{
  "compilerOptions": {
    "rootDir": "./src", 
    "outDir": "./dist",
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      
    "skipLibCheck": true,                                
    "noUncheckedIndexedAccess": true,                    
    "exactOptionalPropertyTypes": true,
    "typeRoots": ["./node_modules/@types", "./src/@types"]                   
  },
  "include": ["src/**/*"]                                
}